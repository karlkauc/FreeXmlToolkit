{
  "name": "FundsXML Bond Fund EAM Demo",
  "description": "Generates a schema-valid FundsXML4 instance modelled on release/examples/xml/FundsXML_422_Bond_Fund.xml. Produces ControlData with the Erste Asset Management identifiers, a Funds/Fund entry with LEI/name/currency, a Portfolio with one Position, and an AssetMasterData entry whose UniqueID matches the Position's IDREF. Uses mandatoryOnly=true and maxOccurrences=1 to keep the output minimal and deterministic.",
  "schemaFile": "FundsXML4.xsd",
  "batchCount": 1,
  "fileNamePattern": "FundsXML_Bond_Fund_{seq:3}.xml",
  "mandatoryOnly": true,
  "maxOccurrences": 1,
  "rules": [
    {
      "xpath": "/FundsXML4/ControlData/UniqueDocumentID",
      "strategy": "FIXED",
      "config": {"value": "EAM_FUND_003"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/ControlData/ContentDate",
      "strategy": "FIXED",
      "config": {"value": "2021-11-30"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/ControlData/DataOperation",
      "strategy": "FIXED",
      "config": {"value": "INITIAL"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/ControlData/Language",
      "strategy": "FIXED",
      "config": {"value": "EN"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "//DataSupplier/SystemCountry",
      "strategy": "FIXED",
      "config": {"value": "AT"},
      "priority": 5,
      "enabled": true
    },
    {
      "xpath": "//DataSupplier/Short",
      "strategy": "FIXED",
      "config": {"value": "EAM"},
      "priority": 5,
      "enabled": true
    },
    {
      "xpath": "//DataSupplier/Name",
      "strategy": "FIXED",
      "config": {"value": "Erste Asset Management GmbH"},
      "priority": 5,
      "enabled": true
    },
    {
      "xpath": "//DataSupplier/Type",
      "strategy": "FIXED",
      "config": {"value": "Asset Manager"},
      "priority": 5,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/Identifiers/LEI",
      "strategy": "FIXED",
      "config": {"value": "PQOH26KWDF7CG10L6792"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/Names/OfficialName",
      "strategy": "FIXED",
      "config": {"value": "DEMO BOND FUND"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/Currency",
      "strategy": "FIXED",
      "config": {"value": "EUR"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFundFlag",
      "strategy": "FIXED",
      "config": {"value": "true"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/FundDynamicData/Portfolios/Portfolio/NavDate",
      "strategy": "FIXED",
      "config": {"value": "2021-11-30"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/FundDynamicData/Portfolios/Portfolio/Positions/Position/UniqueID",
      "strategy": "SEQUENCE",
      "config": {"pattern": "ASSET_BOND_{seq:3}", "start": "1", "step": "1"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/AssetMasterData/Asset/UniqueID",
      "strategy": "SEQUENCE",
      "config": {"pattern": "ASSET_BOND_{seq:3}", "start": "1", "step": "1"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/AssetMasterData/Asset",
      "strategy": "AUTO",
      "config": {"maxOccurrences": "3"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/AssetMasterData/Asset/Currency",
      "strategy": "FIXED",
      "config": {"value": "EUR"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/AssetMasterData/Asset/Name",
      "strategy": "FIXED",
      "config": {"value": "DEMO BOND 2030"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/AssetMasterData/Asset/AssetType",
      "strategy": "FIXED",
      "config": {"value": "BO"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "//Amount/@ccy",
      "strategy": "FIXED",
      "config": {"value": "EUR"},
      "priority": 5,
      "enabled": true
    },
    {
      "xpath": "//Bond/Nominal",
      "strategy": "FIXED",
      "config": {"value": "1000000"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/FundDynamicData/Portfolios/Portfolio/Positions/Position",
      "strategy": "AUTO",
      "config": {"maxOccurrences": "3"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/FundDynamicData/TotalAssetValues/TotalAssetValue/NavDate",
      "strategy": "FIXED",
      "config": {"value": "2021-11-30"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/FundDynamicData/TotalAssetValues/TotalAssetValue/TotalAssetNature",
      "strategy": "FIXED",
      "config": {"value": "OFFICIAL"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/FundDynamicData/TotalAssetValues/TotalAssetValue/TotalNetAssetValue/Amount",
      "strategy": "FIXED",
      "config": {"value": "25535819.05"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFund/ShareClasses/ShareClass",
      "strategy": "AUTO",
      "config": {"maxOccurrences": "2"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFund/ShareClasses/ShareClass/Identifiers/ISIN",
      "strategy": "SEQUENCE",
      "config": {"pattern": "AT00000{seq:5}", "start": "10001", "step": "1"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFund/ShareClasses/ShareClass/Names/OfficialName",
      "strategy": "SEQUENCE",
      "config": {"pattern": "DEMO BOND FUND SHARECLASS {seq:1}", "start": "1", "step": "1"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFund/ShareClasses/ShareClass/Currency",
      "strategy": "FIXED",
      "config": {"value": "EUR"},
      "priority": 10,
      "enabled": true
    },

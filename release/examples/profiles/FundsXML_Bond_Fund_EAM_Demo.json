    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFund/ShareClasses/ShareClass/TotalAssetValues/TotalAssetValue/NavDate",
      "strategy": "FIXED",
      "config": {"value": "2021-11-30"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFund/ShareClasses/ShareClass/TotalAssetValues/TotalAssetValue/TotalAssetNature",
      "strategy": "FIXED",
      "config": {"value": "OFFICIAL"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFund/ShareClasses/ShareClass/TotalAssetValues/TotalAssetValue/TotalNetAssetValue/Amount",
      "strategy": "SEQUENCE",
      "config": {"pattern": "1{seq:7}.05", "start": "8245392", "step": "255487"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFund/ShareClasses/ShareClass/TotalAssetValues/TotalAssetValue/SharesOutstanding",
      "strategy": "SEQUENCE",
      "config": {"pattern": "{seq:6}", "start": "131775", "step": "2345"},
      "priority": 10,
      "enabled": true

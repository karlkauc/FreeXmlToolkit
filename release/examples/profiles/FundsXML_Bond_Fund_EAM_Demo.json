      "config": {"value": "2021-11-30"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFund/ShareClasses/ShareClass/Prices/Price/PriceCurrency",
      "strategy": "FIXED",
      "config": {"value": "EUR"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFund/ShareClasses/ShareClass/Prices/Price/PriceNature",
      "strategy": "FIXED",
      "config": {"value": "OFFICIAL"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFund/ShareClasses/ShareClass/Prices/Price/NavPrice",
      "strategy": "SEQUENCE",
      "config": {"pattern": "1{seq:2}.924576", "start": "37", "step": "5"},
      "priority": 10,
      "enabled": true

{
  "name": "FundsXML Bond Fund EAM Demo",
  "description": "Generates a schema-valid FundsXML4 instance modelled on release/examples/xml/FundsXML_422_Bond_Fund.xml. Uses mandatoryOnly=true and maxOccurrences=1 to keep the output minimal and avoid optional sections that contain unresolvable IDREF chains. FIXED rules supply the Erste Asset Management identifiers (LEI, name, email), ContentDate 2021-11-30, EUR currency, INITIAL operation and UCITS legal structure so the result reads as a real EAM bond fund snapshot.",
  "schemaFile": "FundsXML4.xsd",
  "batchCount": 1,
  "fileNamePattern": "FundsXML_Bond_Fund_{seq:3}.xml",
  "mandatoryOnly": true,
  "maxOccurrences": 1,
  "rules": [
    {
      "xpath": "/FundsXML4/ControlData/UniqueDocumentID",
      "strategy": "FIXED",
      "config": {"value": "EAM_FUND_003"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/ControlData/ContentDate",
      "strategy": "FIXED",
      "config": {"value": "2021-11-30"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/ControlData/DataOperation",
      "strategy": "FIXED",
      "config": {"value": "INITIAL"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/ControlData/Language",
      "strategy": "FIXED",
      "config": {"value": "EN"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "//DataSupplier/SystemCountry",
      "strategy": "FIXED",
      "config": {"value": "AT"},
      "priority": 5,
      "enabled": true
    },
    {
      "xpath": "//DataSupplier/Short",
      "strategy": "FIXED",
      "config": {"value": "EAM"},
      "priority": 5,
      "enabled": true
    },
    {
      "xpath": "//DataSupplier/Name",
      "strategy": "FIXED",
      "config": {"value": "Erste Asset Management GmbH"},
      "priority": 5,
      "enabled": true
    },
    {
      "xpath": "//DataSupplier/Type",
      "strategy": "FIXED",
      "config": {"value": "Asset Manager"},
      "priority": 5,
      "enabled": true
    },
    {
      "xpath": "//DataSupplier/Contact/Email",
      "strategy": "FIXED",
      "config": {"value": "datamanagement@erste-am.com"},
      "priority": 5,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/Identifiers/LEI",
      "strategy": "FIXED",
      "config": {"value": "PQOH26KWDF7CG10L6792"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/Names/OfficialName",
      "strategy": "FIXED",
      "config": {"value": "DEMO BOND FUND"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/Currency",
      "strategy": "FIXED",
      "config": {"value": "EUR"},
      "priority": 10,
      "enabled": true
    },
    {
      "xpath": "/FundsXML4/Funds/Fund/SingleFundFlag",
      "strategy": "FIXED",
      "config": {"value": "true"},
      "priority": 10,
      "enabled": true
    }
  ]
}

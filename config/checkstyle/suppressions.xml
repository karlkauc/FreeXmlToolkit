<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<!--
    Checkstyle suppressions for FreeXmlToolkit.
    Suppress known false positives and demo code.
-->
<suppressions>
    <!-- Suppress all checks for demo code -->
    <suppress files="[/\\]demo[/\\]" checks=".*"/>

    <!-- Suppress naming checks for FXML-injected fields (often match component IDs) -->
    <suppress files=".*Controller\.java$" checks="MemberName" message=".*"/>

    <!-- Suppress LineLength only for files dominated by long literal data/markup that cannot be
         meaningfully wrapped: bundled icon path data and the SVG/HTML/image documentation generators. -->
    <suppress checks="LineLength" files="BootstrapIconPaths\.java$"/>
    <suppress checks="LineLength" files="XsdTypeIconPaths\.java$"/>
    <suppress checks="LineLength" files="XsdDocumentationSvgService\.java$"/>
    <suppress checks="LineLength" files="XsdDocumentationImageService\.java$"/>
    <suppress checks="LineLength" files="XsdDocumentationHtmlService\.java$"/>
    <suppress checks="LineLength" files="ModernXmlThemeManager\.java$"/>
    <suppress checks="LineLength" files="XsdNodeRenderer\.java$"/>
    <suppress checks="LineLength" files="SectionSettingsPopup\.java$"/>
</suppressions>

<?xml version="1.0"?>
<ruleset name="FreeXmlToolkit PMD Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>
        PMD ruleset for FreeXmlToolkit — a gating, "no false positives" set.
        Focus: unused code, resource/exception correctness, and clearly-beneficial
        best-practice/style rules that are mechanically fixable. Noisy, debatable, or
        risky-to-fix rules are intentionally excluded (see the comments below) so the
        gate stays meaningful and green rather than being silenced wholesale.
    </description>

    <!-- Exclude demo package from analysis -->
    <exclude-pattern>.*/demo/.*</exclude-pattern>

    <!-- ==================== Unused Code ==================== -->
    <rule ref="category/java/bestpractices.xml/UnusedPrivateField"/>
    <rule ref="category/java/bestpractices.xml/UnusedPrivateMethod"/>
    <rule ref="category/java/bestpractices.xml/UnusedLocalVariable"/>
    <rule ref="category/java/bestpractices.xml/UnusedFormalParameter">
        <properties>
            <property name="checkAll" value="false"/>
        </properties>
    </rule>

    <!-- ==================== Error-Prone ==================== -->
    <rule ref="category/java/errorprone.xml/EmptyCatchBlock">
        <properties>
            <property name="allowCommentedBlocks" value="true"/>
            <property name="allowExceptionNameRegex" value="^(ignored|expected)$"/>
        </properties>
    </rule>
    <rule ref="category/java/errorprone.xml/ReturnFromFinallyBlock"/>
    <rule ref="category/java/errorprone.xml/CloseResource"/>
    <rule ref="category/java/errorprone.xml/ImplicitSwitchFallThrough"/>
    <rule ref="category/java/errorprone.xml/EqualsNull"/>
    <rule ref="category/java/errorprone.xml/AvoidDecimalLiteralsInBigDecimalConstructor"/>

    <!-- ==================== Best Practices ==================== -->
    <rule ref="category/java/bestpractices.xml/MissingOverride"/>
    <rule ref="category/java/bestpractices.xml/PreserveStackTrace"/>
    <rule ref="category/java/bestpractices.xml/ForLoopCanBeForeach"/>
    <rule ref="category/java/bestpractices.xml/UseTryWithResources"/>
    <rule ref="category/java/bestpractices.xml/DefaultLabelNotLastInSwitch"/>

    <!-- ==================== Design ==================== -->
    <rule ref="category/java/design.xml/SimplifyBooleanReturns"/>
    <rule ref="category/java/design.xml/CollapsibleIfStatements"/>
    <rule ref="category/java/design.xml/SimplifiedTernary"/>
    <rule ref="category/java/design.xml/UselessOverridingMethod"/>

    <!-- ==================== Code Style ==================== -->
    <rule ref="category/java/codestyle.xml/UnnecessaryImport"/>
    <rule ref="category/java/codestyle.xml/UnnecessaryReturn"/>
    <rule ref="category/java/codestyle.xml/UnnecessaryCast"/>
    <rule ref="category/java/codestyle.xml/ExtendsObject"/>
    <rule ref="category/java/codestyle.xml/EmptyControlStatement"/>

    <!-- ==================== Performance ==================== -->
    <rule ref="category/java/performance.xml/StringInstantiation"/>
    <rule ref="category/java/performance.xml/AvoidArrayLoops"/>

    <!--
        ==================== Intentionally excluded ====================
        These rules were evaluated against the codebase and removed from the gate
        because their findings here are noise, debatable, or require risky refactoring
        of working code. Removing them (rather than blanket-suppressing) keeps the gate
        honest and reviewable. Re-enable individually with a dedicated cleanup effort.

        - CompareObjectsWithEquals: ~90 hits, all intentional identity comparisons
          (JavaFX ButtonType singletons, event sources, tree-/model-node identity).
          Converting to .equals() would introduce real bugs.
        - ConstructorCallsOverridableMethod: ~79 hits; common and benign in JavaFX
          control construction.
        - AvoidCatchingGenericException: ~409 hits; catching Exception is frequently
          the correct, intentional choice in this UI/IO code.
        - GuardLogStatement: ~997 hits; pointless with Log4j2 parameterized ("{}")
          logging, which this project uses.
        - AvoidReassigningParameters: debatable style preference.
        - UnusedAssignment: ~15 hits, mostly false positives on re-entrancy/debounce
          guard flags (e.g. `updating`, `suppressDebounce`) whose reads live in listener
          callbacks PMD's intra-procedural analysis cannot see. Removing the assignments
          would break the guards.
        - FinalFieldCouldBeStatic: the lone hit is a per-instance mutable array
          (`boolean[] dirty`); making it static would be a bug.
        - UseStringBufferForStringAppends: all hits are single conditional string
          concatenations (e.g. `name += ":" + x`), not loop accumulation; a StringBuilder
          would only obscure them.
        - CyclomaticComplexity / NPathComplexity / NcssCount / ExcessiveParameterList /
          TooManyFields / TooManyMethods: ~291 hits; flag large existing methods/classes.
          Refactoring is high-risk and belongs in dedicated, separately-reviewed work,
          not a static-analysis gate.
    -->
</ruleset>

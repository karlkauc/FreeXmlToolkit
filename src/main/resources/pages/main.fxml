<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import org.fxt.freexmltoolkit.controls.icons.IconifyIcon?>
<AnchorPane prefHeight="800.0" prefWidth="1400.0"
            stylesheets="@../css/design-tokens.css, @../css/app-theme.css, @../css/fxt-theme.css"
            xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.fxt.freexmltoolkit.controller.MainController">

    <BorderPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                AnchorPane.topAnchor="0.0">
        <top>
            <MenuBar>
                <Menu text="File">
                    <graphic>
                        <IconifyIcon iconLiteral="bi-folder" iconSize="16" iconColor="#17a2b8"/>
                    </graphic>
                    <MenuItem fx:id="menuItemNew" onAction="#handleNewFile" text="New" accelerator="Shortcut+N">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-file-earmark-plus" iconSize="16" iconColor="#28a745"/>
                        </graphic>
                    </MenuItem>
                    <MenuItem fx:id="menuItemOpen" onAction="#handleOpenFile" text="Open..." accelerator="Shortcut+O">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-folder2-open" iconSize="16" iconColor="#007bff"/>
                        </graphic>
                    </MenuItem>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="menuItemSave" onAction="#handleSave" text="Save" accelerator="Shortcut+S">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-floppy" iconSize="16" iconColor="#17a2b8"/>
                        </graphic>
                    </MenuItem>
                    <MenuItem fx:id="menuItemSaveAs" onAction="#handleSaveAs" text="Save As..."
                              accelerator="Shortcut+Shift+S">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-floppy-fill" iconSize="16" iconColor="#17a2b8"/>
                        </graphic>
                    </MenuItem>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="menuItemClose" onAction="#handleClose" text="Close" accelerator="Shortcut+W">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-x-circle" iconSize="16" iconColor="#dc3545"/>
                        </graphic>
                    </MenuItem>
                    <MenuItem fx:id="menuItemCloseAll" onAction="#handleCloseAll" text="Close All">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-x-square" iconSize="16" iconColor="#dc3545"/>
                        </graphic>
                    </MenuItem>
                    <SeparatorMenuItem/>
                    <Menu fx:id="lastOpenFilesMenu" text="Recent Files">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-clock-history" iconSize="16" iconColor="#6f42c1"/>
                        </graphic>
                    </Menu>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="menuItemSettings" onAction="#openSettings" text="Settings...">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-gear" iconSize="16" iconColor="#6c757d"/>
                        </graphic>
                    </MenuItem>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="menuItemExit" onAction="#handleExit" text="Exit">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-door-closed" iconSize="16" iconColor="#495057"/>
                        </graphic>
                    </MenuItem>
                </Menu>
                <Menu text="Edit">
                    <graphic>
                        <IconifyIcon iconLiteral="bi-pencil" iconSize="16" iconColor="#6f42c1"/>
                    </graphic>
                    <MenuItem fx:id="menuItemUndo" onAction="#handleUndo" text="Undo" accelerator="Shortcut+Z">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-arrow-counterclockwise" iconSize="16" iconColor="#17a2b8"/>
                        </graphic>
                    </MenuItem>
                    <MenuItem fx:id="menuItemRedo" onAction="#handleRedo" text="Redo" accelerator="Shortcut+Shift+Z">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-arrow-clockwise" iconSize="16" iconColor="#17a2b8"/>
                        </graphic>
                    </MenuItem>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="menuItemFind" onAction="#handleFind" text="Find..." accelerator="Shortcut+F">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-search" iconSize="16" iconColor="#6f42c1"/>
                        </graphic>
                    </MenuItem>
                    <MenuItem fx:id="menuItemFindReplace" onAction="#handleFindReplace" text="Find &amp; Replace..."
                              accelerator="Shortcut+H">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-arrow-left-right" iconSize="16" iconColor="#6f42c1"/>
                        </graphic>
                    </MenuItem>
                </Menu>

                <!-- XSD Tools Menu -->
                <Menu text="XSD Tools">
                    <graphic>
                        <IconifyIcon iconLiteral="bi-diagram-3" iconSize="16" iconColor="#9c27b0"/>
                    </graphic>
                    <items>
                        <MenuItem fx:id="menuTypeLibrary" text="Type Library..." onAction="#openTypeLibrary">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-collection" iconSize="16" iconColor="#6f42c1"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="menuTypeEditor" text="Type Editor..." onAction="#openTypeEditor">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-pencil-square" iconSize="16" iconColor="#6f42c1"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="menuSchemaAnalysis" text="Schema Analysis..." onAction="#openSchemaAnalysis">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-bar-chart-line" iconSize="16" iconColor="#17a2b8"/>
                            </graphic>
                        </MenuItem>
                        <SeparatorMenuItem/>
                        <MenuItem fx:id="menuXsdDocumentation" text="Documentation Generator..." onAction="#openXsdDocumentation">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-book" iconSize="16" iconColor="#007bff"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="menuGenerateExampleData" text="Generate Example Data..." onAction="#openGenerateExampleData">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-file-earmark-plus" iconSize="16" iconColor="#28a745"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="menuFlattenSchema" text="Flatten Schema..." onAction="#openFlattenSchema">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-layers" iconSize="16" iconColor="#fd7e14"/>
                            </graphic>
                        </MenuItem>
                    </items>
                </Menu>

                <!-- XML Tools Menu -->
                <Menu text="XML Tools">
                    <graphic>
                        <IconifyIcon iconLiteral="bi-file-earmark-code" iconSize="16" iconColor="#fd7e14"/>
                    </graphic>
                    <items>
                        <MenuItem fx:id="menuXsltDeveloper" text="XSLT Developer..." onAction="#openXsltDeveloper">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-arrow-repeat" iconSize="16" iconColor="#fd7e14"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="menuTemplateBuilder" text="Template Builder..." onAction="#openTemplateBuilder">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-file-earmark-ruled" iconSize="16" iconColor="#007bff"/>
                            </graphic>
                        </MenuItem>
                        <SeparatorMenuItem/>
                        <MenuItem fx:id="menuXmlToCsv" text="XML to Excel/CSV..." onAction="#openXmlToCsv">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-table" iconSize="16" iconColor="#28a745"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="menuGenerateSchema" text="Generate Schema from XML..." onAction="#openGenerateSchema">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-gear" iconSize="16" iconColor="#6c757d"/>
                            </graphic>
                        </MenuItem>
                    </items>
                </Menu>

                <!-- Schematron Tools Menu -->
                <Menu text="Schematron Tools">
                    <graphic>
                        <IconifyIcon iconLiteral="bi-shield-check" iconSize="16" iconColor="#ffc107"/>
                    </graphic>
                    <items>
                        <MenuItem fx:id="menuSchematronBuilder" text="Visual Rule Builder..." onAction="#openSchematronBuilder">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-bricks" iconSize="16" iconColor="#ffc107"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="menuSchematronTest" text="Test Rules..." onAction="#openSchematronTest">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-check2-circle" iconSize="16" iconColor="#28a745"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="menuSchematronDocs" text="Generate Documentation..." onAction="#openSchematronDocumentation">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-journal-text" iconSize="16" iconColor="#007bff"/>
                            </graphic>
                        </MenuItem>
                    </items>
                </Menu>

                <!-- Signatures Menu -->
                <Menu text="Signatures">
                    <graphic>
                        <IconifyIcon iconLiteral="bi-shield-lock" iconSize="16" iconColor="#dc3545"/>
                    </graphic>
                    <items>
                        <MenuItem fx:id="menuCreateCertificate" text="Create Certificate..." onAction="#openCreateCertificate">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-award" iconSize="16" iconColor="#ffc107"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="menuSignXml" text="Sign XML Document..." onAction="#openSignXml">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-pen" iconSize="16" iconColor="#007bff"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="menuValidateSignature" text="Validate Signature..." onAction="#openValidateSignature">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-patch-check" iconSize="16" iconColor="#28a745"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="menuExpertSigning" text="Expert Signing Mode..." onAction="#openExpertSigning">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-sliders" iconSize="16" iconColor="#6c757d"/>
                            </graphic>
                        </MenuItem>
                    </items>
                </Menu>

                <Menu fx:id="fundsxmlMenu" text="FundsXML" visible="false">
                    <graphic>
                        <IconifyIcon iconLiteral="bi-collection" iconSize="16" iconColor="#28a745"/>
                    </graphic>
                    <items>
                        <MenuItem fx:id="fundsxmlMenuDownload" text="Download / Update Content..."
                                  onAction="#openFundsXmlDownload">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-cloud-download" iconSize="16" iconColor="#28a745"/>
                            </graphic>
                        </MenuItem>
                        <Menu fx:id="fundsxmlMenuActiveVersion" text="Active Schema Version">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-tag" iconSize="16" iconColor="#17a2b8"/>
                            </graphic>
                        </Menu>
                        <SeparatorMenuItem/>
                        <MenuItem fx:id="fundsxmlMenuValidate" text="Validate Current XML Against FundsXML"
                                  onAction="#validateAgainstFundsXml"
                                  accelerator="Shortcut+Shift+F">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-shield-check" iconSize="16" iconColor="#28a745"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="fundsxmlMenuGenerateDocs" text="Generate Schema Documentation..."
                                  onAction="#generateFundsXmlSchemaDocumentation">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-file-earmark-richtext" iconSize="16" iconColor="#6f42c1"/>
                            </graphic>
                        </MenuItem>
                        <SeparatorMenuItem/>
                        <MenuItem fx:id="fundsxmlMenuOpenExamples" text="Open Examples Folder"
                                  onAction="#openFundsXmlExamplesFolder">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-folder2-open" iconSize="16" iconColor="#fd7e14"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="fundsxmlMenuOpenSchema" text="Open Schema Folder"
                                  onAction="#openFundsXmlSchemaFolder">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-folder2-open" iconSize="16" iconColor="#007bff"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="fundsxmlMenuOpenSchematron" text="Open Schematron Folder"
                                  onAction="#openFundsXmlSchematronFolder">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-folder2-open" iconSize="16" iconColor="#dc3545"/>
                            </graphic>
                        </MenuItem>
                        <SeparatorMenuItem/>
                        <MenuItem fx:id="fundsxmlMenuOnlineDocs" text="Open FundsXML Online Docs"
                                  onAction="#openFundsXmlOnlineDocs">
                            <graphic>
                                <IconifyIcon iconLiteral="bi-box-arrow-up-right" iconSize="16" iconColor="#007bff"/>
                            </graphic>
                        </MenuItem>
                    </items>
                </Menu>

                <Menu text="Window">
                    <graphic>
                        <IconifyIcon iconLiteral="bi-window" iconSize="16" iconColor="#1e88e5"/>
                    </graphic>
                    <CheckMenuItem fx:id="showMenuMenuItem" onAction="#toggleMenuBar" text="Show Menu">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-menu-up" iconSize="16" iconColor="#6c757d"/>
                        </graphic>
                    </CheckMenuItem>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="menuItemFullScreen" onAction="#toggleFullScreen" text="Full Screen"
                              accelerator="F11">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-fullscreen" iconSize="16" iconColor="#1e88e5"/>
                        </graphic>
                    </MenuItem>
                </Menu>
                <Menu text="Help">
                    <graphic>
                        <IconifyIcon iconLiteral="bi-question-circle" iconSize="16" iconColor="#007bff"/>
                    </graphic>
                    <MenuItem fx:id="menuItemUserGuide" onAction="#openUserGuide" text="User Guide">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-book" iconSize="16" iconColor="#007bff"/>
                        </graphic>
                    </MenuItem>
                    <MenuItem fx:id="menuItemKeyboardShortcuts" onAction="#showKeyboardShortcuts"
                              text="Keyboard Shortcuts">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-keyboard" iconSize="16" iconColor="#6c757d"/>
                        </graphic>
                    </MenuItem>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="menuItemCheckUpdates" onAction="#checkForUpdates" text="Check for Updates">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-cloud-download" iconSize="16" iconColor="#28a745"/>
                        </graphic>
                    </MenuItem>
                    <MenuItem fx:id="menuItemReportIssue" onAction="#reportIssue" text="Report Issue">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-github" iconSize="16" iconColor="#495057"/>
                        </graphic>
                    </MenuItem>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="menuItemAbout" onAction="#handleAboutAction" text="About FreeXmlToolkit">
                        <graphic>
                            <IconifyIcon iconLiteral="bi-info-circle" iconSize="16" iconColor="#17a2b8"/>
                        </graphic>
                    </MenuItem>
                </Menu>
            </MenuBar>
        </top>
        <bottom>
            <HBox fx:id="bottomLine" styleClass="bottom_line" BorderPane.alignment="CENTER">
                <VBox alignment="CENTER_LEFT">
                    <Label fx:id="version" contentDisplay="CENTER" text="Version">
                        <font>
                            <Font size="12.0"/>
                        </font>
                        <opaqueInsets>
                            <Insets/>
                        </opaqueInsets>
                        <VBox.margin>
                            <Insets left="10.0"/>
                        </VBox.margin>
                    </Label>
                </VBox>
            </HBox>
        </bottom>
        <left>
            <VBox fx:id="leftMenu" styleClass="menu_box" AnchorPane.bottomAnchor="0" AnchorPane.topAnchor="0" alignment="CENTER">
                <VBox style="-fx-padding: 5px" alignment="CENTER" onMouseClicked="#toggleMenuBar">
                    <ImageView fx:id="logoImageView" fitHeight="75" fitWidth="100" pickOnBounds="true"
                               preserveRatio="true">
                        <Image url="@../img/logo.png"/>
                    </ImageView>
                    <Label fx:id="menuText1" text="FundsXML Toolkit" styleClass="h3"/>
                    <Label fx:id="menuText2" text="Enterprise Edition"/>
                </VBox>
                <BorderPane VBox.vgrow="ALWAYS">
                    <center>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    styleClass="sidebar-scroll-pane">
                            <VBox alignment="CENTER">
                                <!-- Section: EDITORS -->
                                <Label fx:id="sectionEditors" text="EDITORS" styleClass="sidebar-section-label"/>

                                <Button fx:id="unifiedShell" mnemonicParsing="false" onAction="#loadPage"
                                        styleClass="menu_button" text="Editor" contentDisplay="LEFT" VBox.vgrow="ALWAYS">
                                    <graphic>
                                        <IconifyIcon iconColor="#3b5bdb" iconLiteral="bi-layout-sidebar-inset" iconSize="16"/>
                                    </graphic>
                                </Button>

                                <Button mnemonicParsing="false" onAction="#loadPage" styleClass="menu_button"
                                        text="XML Editor" contentDisplay="LEFT" fx:id="xmlUltimate">
                                    <graphic>
                                        <IconifyIcon iconLiteral="bi-code-slash" iconSize="16"/>
                                    </graphic>
                                </Button>

                                <!-- Section: SCHEMA -->
                                <Separator fx:id="separatorSchema" styleClass="sidebar-section-separator"/>
                                <Label fx:id="sectionSchema" text="SCHEMA" styleClass="sidebar-section-label"/>

                                <Button onAction="#loadPage" styleClass="menu_button" text="XSD Editor" contentDisplay="LEFT" VBox.vgrow="ALWAYS"
                                        fx:id="xsd">
                                    <graphic>
                                        <IconifyIcon iconColor="#007bff" iconLiteral="bi-diagram-3" iconSize="16"/>
                                    </graphic>
                                </Button>

                                <!-- Section: TRANSFORMS -->
                                <Separator fx:id="separatorTransforms" styleClass="sidebar-section-separator"/>
                                <Label fx:id="sectionTransforms" text="TRANSFORMS" styleClass="sidebar-section-label"/>

                                <Button fx:id="xsltDeveloper" mnemonicParsing="false" onAction="#loadPage"
                                        styleClass="menu_button" text="XSLT Developer" contentDisplay="LEFT" VBox.vgrow="ALWAYS">
                                    <graphic>
                                        <IconifyIcon iconColor="#fd7e14" iconLiteral="bi-braces" iconSize="16"/>
                                    </graphic>
                                </Button>

                                <!-- Section: TOOLS -->
                                <Separator fx:id="separatorTools" styleClass="sidebar-section-separator"/>
                                <Label fx:id="sectionTools" text="TOOLS" styleClass="sidebar-section-label"/>

                                <Button mnemonicParsing="false" onAction="#loadPage" styleClass="menu_button"
                                        text="Schematron Editor" contentDisplay="LEFT" VBox.vgrow="ALWAYS" fx:id="schematron">
                                    <graphic>
                                        <IconifyIcon iconColor="#ffc107" iconLiteral="bi-shield-check" iconSize="16"/>
                                    </graphic>
                                </Button>

                                <Button fx:id="signature" mnemonicParsing="false" onAction="#loadPage"
                                        styleClass="menu_button" text="Signature" contentDisplay="LEFT" VBox.vgrow="ALWAYS">
                                    <graphic>
                                        <IconifyIcon iconColor="#28a745" iconLiteral="bi-key" iconSize="16"/>
                                    </graphic>
                                </Button>
                            </VBox>
                        </ScrollPane>
                    </center>
                    <bottom>
                        <VBox fx:id="bottomButtonBar" alignment="CENTER" styleClass="sidebar-bottom-bar">
                            <Separator styleClass="sidebar-section-separator"/>
                            <HBox fx:id="bottomButtonRow" alignment="CENTER" spacing="0">
                                <Button fx:id="settings" mnemonicParsing="false" onAction="#loadPage"
                                        styleClass="menu_button" text="Settings" contentDisplay="GRAPHIC_ONLY" HBox.hgrow="ALWAYS">
                                    <graphic>
                                        <IconifyIcon iconLiteral="bi-gear-fill" iconSize="16"/>
                                    </graphic>
                                    <tooltip>
                                        <Tooltip text="Settings"/>
                                    </tooltip>
                                </Button>
                                <Button fx:id="exit" styleClass="menu_button" text="Exit" contentDisplay="GRAPHIC_ONLY" HBox.hgrow="ALWAYS">
                                    <graphic>
                                        <IconifyIcon iconColor="#495057" iconLiteral="bi-door-closed" iconSize="16"/>
                                    </graphic>
                                    <tooltip>
                                        <Tooltip text="Exit"/>
                                    </tooltip>
                                </Button>
                            </HBox>
                        </VBox>
                    </bottom>
                </BorderPane>
            </VBox>
        </left>
        <center>
            <AnchorPane fx:id="contentPane"
                        AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                        AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" />
        </center>
    </BorderPane>
</AnchorPane>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>
<VBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
      AnchorPane.topAnchor="0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.fxt.freexmltoolkit.controller.UnifiedEditorController"
      stylesheets="@../css/xsd-tab-groups.css, @../css/unified-editor.css">

    <!-- Unified Editor Toolbar -->
    <ToolBar styleClass="xsd-toolbar">
        <!-- New File Menu -->
        <MenuButton fx:id="newFileMenu" text="New" contentDisplay="LEFT" styleClass="toolbar-button">
            <graphic>
                <FontIcon iconLiteral="bi-file-earmark-plus" iconSize="20" iconColor="#28a745" styleClass="toolbar-icon-success"/>
            </graphic>
            <tooltip>
                <Tooltip text="Create New File"/>
            </tooltip>
            <items>
                <MenuItem text="XML File" onAction="#newXmlFile">
                    <graphic>
                        <FontIcon iconLiteral="bi-file-earmark-code" iconSize="16" iconColor="#007bff"/>
                    </graphic>
                </MenuItem>
                <MenuItem text="XSD Schema" onAction="#newXsdFile">
                    <graphic>
                        <FontIcon iconLiteral="bi-diagram-3" iconSize="16" iconColor="#28a745"/>
                    </graphic>
                </MenuItem>
                <MenuItem text="XSLT Stylesheet" onAction="#newXsltFile">
                    <graphic>
                        <FontIcon iconLiteral="bi-arrow-repeat" iconSize="16" iconColor="#fd7e14"/>
                    </graphic>
                </MenuItem>
                <MenuItem text="Schematron" onAction="#newSchematronFile">
                    <graphic>
                        <FontIcon iconLiteral="bi-shield-check" iconSize="16" iconColor="#6f42c1"/>
                    </graphic>
                </MenuItem>
                <SeparatorMenuItem/>
                <MenuItem text="JSON File" onAction="#newJsonFile">
                    <graphic>
                        <FontIcon iconLiteral="bi-braces" iconSize="16" iconColor="#fd7e14"/>
                    </graphic>
                </MenuItem>
            </items>
        </MenuButton>

        <Button fx:id="openFileButton" text="Open" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#openFile">
            <graphic>
                <FontIcon iconLiteral="bi-folder2-open" iconSize="20" iconColor="#007bff" styleClass="toolbar-icon-primary"/>
            </graphic>
            <tooltip>
                <Tooltip text="Open File (Ctrl+O)"/>
            </tooltip>
        </Button>

        <Button fx:id="saveButton" text="Save" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#saveCurrentTab">
            <graphic>
                <FontIcon iconLiteral="bi-save" iconSize="20" iconColor="#17a2b8" styleClass="toolbar-icon-info"/>
            </graphic>
            <tooltip>
                <Tooltip text="Save (Ctrl+S)"/>
            </tooltip>
        </Button>

        <Button fx:id="saveAllButton" text="Save All" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#saveAllTabs">
            <graphic>
                <FontIcon iconLiteral="bi-save-fill" iconSize="20" iconColor="#17a2b8" styleClass="toolbar-icon-info"/>
            </graphic>
            <tooltip>
                <Tooltip text="Save All (Ctrl+Shift+S)"/>
            </tooltip>
        </Button>

        <MenuButton fx:id="recentFilesMenu" text="Recent" contentDisplay="LEFT" styleClass="toolbar-button">
            <graphic>
                <FontIcon iconLiteral="bi-clock-history" iconSize="20" iconColor="#6c757d" styleClass="toolbar-icon-secondary"/>
            </graphic>
            <tooltip>
                <Tooltip text="Recent Files (Ctrl+Shift+R)"/>
            </tooltip>
        </MenuButton>

        <Separator orientation="VERTICAL"/>

        <Button fx:id="closeTabButton" text="Close" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#closeCurrentTab">
            <graphic>
                <FontIcon iconLiteral="bi-x-circle" iconSize="20" iconColor="#dc3545" styleClass="toolbar-icon-danger"/>
            </graphic>
            <tooltip>
                <Tooltip text="Close Current Tab (Ctrl+W)"/>
            </tooltip>
        </Button>

        <Separator orientation="VERTICAL"/>

        <Button fx:id="validateButton" text="Validate" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#validateCurrentTab">
            <graphic>
                <FontIcon iconLiteral="bi-check-circle" iconSize="20" iconColor="#28a745" styleClass="toolbar-icon-success"/>
            </graphic>
            <tooltip>
                <Tooltip text="Validate (F5)"/>
            </tooltip>
        </Button>

        <Button fx:id="formatButton" text="Format" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#formatCurrentTab">
            <graphic>
                <FontIcon iconLiteral="bi-text-left" iconSize="20" iconColor="#6c757d" styleClass="toolbar-icon-secondary"/>
            </graphic>
            <tooltip>
                <Tooltip text="Format/Pretty Print (Ctrl+Shift+F)"/>
            </tooltip>
        </Button>

        <Separator orientation="VERTICAL"/>

        <Button fx:id="undoButton" text="Undo" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#undo">
            <graphic>
                <FontIcon iconLiteral="bi-arrow-counterclockwise" iconSize="20" iconColor="#6c757d" styleClass="toolbar-icon-secondary"/>
            </graphic>
            <tooltip>
                <Tooltip text="Undo (Ctrl+Z)"/>
            </tooltip>
        </Button>

        <Button fx:id="redoButton" text="Redo" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#redo">
            <graphic>
                <FontIcon iconLiteral="bi-arrow-clockwise" iconSize="20" iconColor="#6c757d" styleClass="toolbar-icon-secondary"/>
            </graphic>
            <tooltip>
                <Tooltip text="Redo (Ctrl+Y)"/>
            </tooltip>
        </Button>

        <Separator orientation="VERTICAL"/>

        <!-- View Mode Switcher -->
        <MenuButton fx:id="viewModeMenu" text="View" contentDisplay="LEFT" styleClass="toolbar-button">
            <graphic>
                <FontIcon iconLiteral="bi-layout-sidebar" iconSize="20" iconColor="#17a2b8" styleClass="toolbar-icon-info"/>
            </graphic>
            <tooltip>
                <Tooltip text="Switch View Mode (Tabs/Split)"/>
            </tooltip>
            <items>
                <MenuItem text="Tabs View" onAction="#setViewModeTabs">
                    <graphic>
                        <FontIcon iconLiteral="bi-segmented-nav" iconSize="16" iconColor="#6c757d"/>
                    </graphic>
                </MenuItem>
                <MenuItem text="Side-by-Side" onAction="#setViewModeSplitSideBySide">
                    <graphic>
                        <FontIcon iconLiteral="bi-layout-split" iconSize="16" iconColor="#007bff"/>
                    </graphic>
                </MenuItem>
                <MenuItem text="Top-Bottom" onAction="#setViewModeSplitTopBottom">
                    <graphic>
                        <FontIcon iconLiteral="bi-layout-three-columns" iconSize="16" iconColor="#fd7e14" rotate="90"/>
                    </graphic>
                </MenuItem>
            </items>
        </MenuButton>

        <Separator orientation="VERTICAL"/>

        <!-- XML Tools Section -->
        <MenuButton fx:id="convertMenu" text="Convert" contentDisplay="LEFT" styleClass="toolbar-button">
            <graphic>
                <FontIcon iconLiteral="bi-table" iconSize="20" iconColor="#17a2b8" styleClass="toolbar-icon-info"/>
            </graphic>
            <tooltip>
                <Tooltip text="Convert XML to/from Spreadsheets (Ctrl+E)"/>
            </tooltip>
            <items>
                <MenuItem text="XML to Excel/CSV..." onAction="#showXmlToSpreadsheet">
                    <graphic>
                        <FontIcon iconLiteral="bi-file-earmark-excel" iconSize="16" iconColor="#28a745"/>
                    </graphic>
                </MenuItem>
                <MenuItem text="Excel/CSV to XML..." onAction="#showSpreadsheetToXml">
                    <graphic>
                        <FontIcon iconLiteral="bi-file-earmark-code" iconSize="16" iconColor="#007bff"/>
                    </graphic>
                </MenuItem>
            </items>
        </MenuButton>

        <Button fx:id="templatesButton" text="Templates" contentDisplay="LEFT" styleClass="toolbar-button"
                onAction="#showTemplates">
            <graphic>
                <FontIcon iconLiteral="bi-file-earmark-ruled" iconSize="20" iconColor="#ffc107"
                          styleClass="toolbar-icon-warning"/>
            </graphic>
            <tooltip>
                <Tooltip text="XML Templates (Ctrl+T)"/>
            </tooltip>
        </Button>

        <Button fx:id="generatorButton" text="Generator" contentDisplay="LEFT" styleClass="toolbar-button"
                onAction="#showGenerator">
            <graphic>
                <FontIcon iconLiteral="bi-lightning" iconSize="20" iconColor="#6f42c1"
                          styleClass="toolbar-icon-purple"/>
            </graphic>
            <tooltip>
                <Tooltip text="Generate XSD from XML (Ctrl+G)"/>
            </tooltip>
        </Button>

        <!-- JSON-specific tools (shown only when JSON tab is active) -->
        <Separator orientation="VERTICAL"/>

        <Button fx:id="minifyButton" text="Minify" contentDisplay="LEFT" styleClass="toolbar-button"
                onAction="#minifyJson" visible="false" managed="false">
            <graphic>
                <FontIcon iconLiteral="bi-arrows-collapse" iconSize="20" iconColor="#fd7e14"
                          styleClass="toolbar-icon-orange"/>
            </graphic>
            <tooltip>
                <Tooltip text="Minify JSON (remove whitespace)"/>
            </tooltip>
        </Button>

        <MenuButton fx:id="jsonSchemaMenu" text="Schema" contentDisplay="LEFT" styleClass="toolbar-button"
                    visible="false" managed="false">
            <graphic>
                <FontIcon iconLiteral="bi-file-earmark-check" iconSize="20" iconColor="#28a745"
                          styleClass="toolbar-icon-success"/>
            </graphic>
            <tooltip>
                <Tooltip text="JSON Schema Validation"/>
            </tooltip>
            <items>
                <MenuItem text="Load Schema..." onAction="#loadJsonSchema">
                    <graphic>
                        <FontIcon iconLiteral="bi-folder2-open" iconSize="16" iconColor="#007bff"/>
                    </graphic>
                </MenuItem>
                <MenuItem text="Clear Schema" onAction="#clearJsonSchema">
                    <graphic>
                        <FontIcon iconLiteral="bi-x-circle" iconSize="16" iconColor="#dc3545"/>
                    </graphic>
                </MenuItem>
                <SeparatorMenuItem/>
                <MenuItem text="Validate Against Schema" onAction="#validateJsonAgainstSchema">
                    <graphic>
                        <FontIcon iconLiteral="bi-check-circle" iconSize="16" iconColor="#28a745"/>
                    </graphic>
                </MenuItem>
            </items>
        </MenuButton>

        <!-- XML-specific tools (shown only when XML tab is active) -->
        <ToggleButton fx:id="consolePanelToggle" text="Console" contentDisplay="LEFT" styleClass="toolbar-button"
                      onAction="#toggleConsolePanel" visible="false" managed="false">
            <graphic>
                <FontIcon iconLiteral="bi-terminal" iconSize="20" iconColor="#6c757d"
                          styleClass="toolbar-icon-secondary"/>
            </graphic>
            <tooltip>
                <Tooltip text="Toggle Console Panel"/>
            </tooltip>
        </ToggleButton>

        <ToggleButton fx:id="xsltDevPanelToggle" text="XSLT" contentDisplay="LEFT" styleClass="toolbar-button"
                      onAction="#toggleXsltDevPanel" visible="false" managed="false">
            <graphic>
                <FontIcon iconLiteral="bi-arrow-repeat" iconSize="20" iconColor="#fd7e14"
                          styleClass="toolbar-icon-orange"/>
            </graphic>
            <tooltip>
                <Tooltip text="Toggle Embedded XSLT Development Panel"/>
            </tooltip>
        </ToggleButton>

        <ToggleButton fx:id="templateDevPanelToggle" text="Template" contentDisplay="LEFT" styleClass="toolbar-button"
                      onAction="#toggleTemplateDevPanel" visible="false" managed="false">
            <graphic>
                <FontIcon iconLiteral="bi-file-earmark-ruled" iconSize="20" iconColor="#ffc107"
                          styleClass="toolbar-icon-warning"/>
            </graphic>
            <tooltip>
                <Tooltip text="Toggle Template Development Panel"/>
            </tooltip>
        </ToggleButton>

        <!-- Schematron-specific tools (shown only when Schematron tab is active) -->
        <MenuButton fx:id="schematronInsertMenu" text="Insert" contentDisplay="LEFT" styleClass="toolbar-button"
                    visible="false" managed="false">
            <graphic>
                <FontIcon iconLiteral="bi-plus-circle" iconSize="20" iconColor="#6f42c1"
                          styleClass="toolbar-icon-purple"/>
            </graphic>
            <tooltip>
                <Tooltip text="Insert Schematron Element"/>
            </tooltip>
            <items>
                <MenuItem text="New Pattern" onAction="#insertSchematronPattern">
                    <graphic>
                        <FontIcon iconLiteral="bi-grid-3x3-gap" iconSize="16" iconColor="#6f42c1"/>
                    </graphic>
                </MenuItem>
                <MenuItem text="New Rule" onAction="#insertSchematronRule">
                    <graphic>
                        <FontIcon iconLiteral="bi-list-check" iconSize="16" iconColor="#6f42c1"/>
                    </graphic>
                </MenuItem>
                <SeparatorMenuItem/>
                <MenuItem text="Assert" onAction="#insertSchematronAssert">
                    <graphic>
                        <FontIcon iconLiteral="bi-exclamation-triangle" iconSize="16" iconColor="#dc3545"/>
                    </graphic>
                </MenuItem>
                <MenuItem text="Report" onAction="#insertSchematronReport">
                    <graphic>
                        <FontIcon iconLiteral="bi-info-circle" iconSize="16" iconColor="#17a2b8"/>
                    </graphic>
                </MenuItem>
            </items>
        </MenuButton>

        <!-- Tools Menu -->
        <Separator orientation="VERTICAL"/>

        <MenuButton text="Tools" contentDisplay="LEFT" styleClass="toolbar-button">
            <graphic>
                <FontIcon iconLiteral="bi-tools" iconSize="20" iconColor="#6c757d"
                          styleClass="toolbar-icon-secondary"/>
            </graphic>
            <tooltip>
                <Tooltip text="Open Tool Tabs"/>
            </tooltip>
            <items>
                <MenuItem text="PDF Generation (FOP)" onAction="#openFopToolTab">
                    <graphic>
                        <FontIcon iconLiteral="bi-file-earmark-richtext" iconSize="16" iconColor="#dc3545"/>
                    </graphic>
                </MenuItem>
                <MenuItem text="Digital Signatures" onAction="#openSignatureToolTab">
                    <graphic>
                        <FontIcon iconLiteral="bi-shield-lock" iconSize="16" iconColor="#28a745"/>
                    </graphic>
                </MenuItem>
            </items>
        </MenuButton>

        <Region HBox.hgrow="ALWAYS"/>

        <Separator orientation="VERTICAL"/>

        <ToggleButton fx:id="linkedFilesToggle" text="Linked" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#toggleLinkedFilesPanel">
            <graphic>
                <FontIcon iconLiteral="bi-link-45deg" iconSize="20" iconColor="#6f42c1" styleClass="toolbar-icon-purple"/>
            </graphic>
            <tooltip>
                <Tooltip text="Toggle Linked Files Panel (Ctrl+L)"/>
            </tooltip>
        </ToggleButton>

        <ToggleButton fx:id="xpathPanelToggle" text="XPath" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#toggleXPathPanel">
            <graphic>
                <FontIcon iconLiteral="bi-search" iconSize="20" iconColor="#fd7e14" styleClass="toolbar-icon-orange"/>
            </graphic>
            <tooltip>
                <Tooltip text="Toggle XPath/XQuery Panel (Ctrl+Shift+X)"/>
            </tooltip>
        </ToggleButton>

        <ToggleButton fx:id="propertiesToggle" text="Properties" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#togglePropertiesPanel">
            <graphic>
                <FontIcon iconLiteral="bi-sliders" iconSize="20" iconColor="#17a2b8" styleClass="toolbar-icon-info"/>
            </graphic>
            <tooltip>
                <Tooltip text="Toggle Properties Panel (Ctrl+Shift+P)"/>
            </tooltip>
        </ToggleButton>

        <Button fx:id="favoritesButton" text="Favorites" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#showFavoritesPanel">
            <graphic>
                <FontIcon iconLiteral="bi-star" iconSize="20" iconColor="#ffc107" styleClass="toolbar-icon-warning"/>
            </graphic>
            <tooltip>
                <Tooltip text="Show Favorites (Ctrl+Shift+B)"/>
            </tooltip>
        </Button>

        <Button fx:id="addFavoriteButton" text="Add Favorite" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#addCurrentFileToFavorites">
            <graphic>
                <FontIcon iconLiteral="bi-star-fill" iconSize="20" iconColor="#ffc107" styleClass="toolbar-icon-warning"/>
            </graphic>
            <tooltip>
                <Tooltip text="Add Current File to Favorites (Ctrl+D)"/>
            </tooltip>
        </Button>

        <Separator orientation="VERTICAL"/>

        <Button fx:id="helpButton" text="Help" contentDisplay="LEFT" styleClass="toolbar-button" onAction="#showHelp">
            <graphic>
                <FontIcon iconLiteral="bi-question-circle" iconSize="20" iconColor="#17a2b8" styleClass="toolbar-icon-info"/>
            </graphic>
            <tooltip>
                <Tooltip text="Help"/>
            </tooltip>
        </Button>
    </ToolBar>

    <!-- Main Content Area -->
    <SplitPane fx:id="mainSplitPane" VBox.vgrow="ALWAYS" dividerPositions="0.75">
        <!-- Editor Tabs -->
        <TabPane fx:id="editorTabPane" tabClosingPolicy="ALL_TABS" side="TOP">
            <!-- Tabs are dynamically added -->
        </TabPane>

        <!-- Linked Files Panel (Initially Hidden) -->
        <VBox fx:id="linkedFilesPanel" minWidth="200" maxWidth="400" spacing="8" visible="false" managed="false">
            <padding>
                <Insets top="8" right="8" bottom="8" left="8"/>
            </padding>

            <Label text="Linked Files" styleClass="linked-files-header">
                <graphic>
                    <FontIcon iconLiteral="bi-link-45deg" iconSize="16" iconColor="#6f42c1"/>
                </graphic>
            </Label>

            <ListView fx:id="linkedFilesList" VBox.vgrow="ALWAYS">
                <placeholder>
                    <Label text="No linked files detected" styleClass="theme-text-secondary"/>
                </placeholder>
            </ListView>

            <HBox spacing="8">
                <Button text="Open Selected" onAction="#openSelectedLinkedFile" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <graphic>
                        <FontIcon iconLiteral="bi-folder2-open" iconSize="14" iconColor="#007bff"/>
                    </graphic>
                </Button>
                <Button text="Open All" onAction="#openAllLinkedFiles">
                    <graphic>
                        <FontIcon iconLiteral="bi-collection" iconSize="14" iconColor="#28a745"/>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
    </SplitPane>

    <!-- Status Bar -->
    <HBox fx:id="statusBar" spacing="16" styleClass="unified-status-bar">
        <Label fx:id="statusLabel" text="Ready" styleClass="theme-text-secondary">
            <graphic>
                <FontIcon iconLiteral="bi-info-circle" iconSize="14" iconColor="#6c757d"/>
            </graphic>
        </Label>

        <Region HBox.hgrow="ALWAYS"/>

        <Label fx:id="fileTypeLabel" text="" styleClass="status-bar-label"/>

        <Separator orientation="VERTICAL"/>

        <Label fx:id="cursorPositionLabel" text="Ln 1, Col 1" styleClass="status-bar-label"/>

        <Separator orientation="VERTICAL"/>

        <Label fx:id="linkedFilesCountLabel" text="" styleClass="status-bar-label-linked">
            <graphic>
                <FontIcon iconLiteral="bi-link-45deg" iconSize="12" iconColor="#6f42c1"/>
            </graphic>
        </Label>
    </HBox>
</VBox>
